V1 0 -6V 6V
V2 +6V 0 6V
V3 N006 0 AC 1
R§VR_10k N001 N006 6.8k tol=5 pwr=0.25
R2 N004 N001 47k tol=5 pwr=0.25
C1 N004 N005 0.68µ V=50
