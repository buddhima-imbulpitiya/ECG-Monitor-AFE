.ac dec 1000 1m 1meg
.meas AC gain AVG mag(V(n002)) FROM 10m TO 10
.meas AC f1 FIND frequency WHEN mag(V(n002))=gain/sqrt(2) FALL=last
.meas AC f2 FIND frequency WHEN mag(V(n002))=gain/sqrt(2) RISE=1
